{
  "name": "schedulesmcp-mcp",
  "mcpName": "io.github.lxxmng/ocean-schedules",
  "version": "0.1.0",
  "description": "Sailing schedule MCP server — compare ocean carrier schedules, transit times, and on-time reliability across 60+ carriers, 72,000+ forward sailings, and 5,000+ lanes before you book. Reliability from observed actual-vs-scheduled arrivals. Works with Claude, Cursor, and any MCP client.",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "schedulesmcp-mcp": "dist/index.js" },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sailing-schedule",
    "sailing-schedule-mcp",
    "ocean-freight-mcp",
    "ocean-schedules",
    "carrier-reliability",
    "on-time-performance",
    "transit-time",
    "ocean-freight",
    "logistics",
    "supply-chain",
    "shipping",
    "claude",
    "cursor",
    "llm"
  ],
  "author": "SchedulesMCP",
  "license": "MIT",
  "homepage": "https://schedulesmcp.com/mcp",
  "repository": { "type": "git", "url": "https://github.com/lxxmng/schedulesmcp" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  }
}
